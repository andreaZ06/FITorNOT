# Required
DEEPSEEK_API_KEY=

# Optional veto dictionary database
NEON_DATABASE_URL=

# Railway image now provisions Playwright Chromium and enables browser recall
# by default. Set this to 0 only when you explicitly want to disable it.
FITORNOT_ENABLE_BROWSER_AUTOMATION=1
FITORNOT_BROWSER_HEADLESS=true
FITORNOT_BROWSER_TIMEOUT_MS=45000
FITORNOT_BROWSER_SCROLL_ROUNDS=2

# Optional: leave unset on Railway to use the bundled Chromium runtime.
FITORNOT_BROWSER_CHANNEL=

# Optional: inject a trusted Playwright storageState JSON payload for Railway.
# You can paste raw JSON here, or prefix a base64-encoded JSON string with `base64:`.
FITORNOT_BROWSER_STORAGE_STATE=

# Optional only when reusing a trusted remote Chrome session
FITORNOT_BROWSER_CDP_URL=
