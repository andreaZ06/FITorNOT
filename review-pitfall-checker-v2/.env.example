# Required
DEEPSEEK_API_KEY=

# Recommended when Bright Data MCP fallback is enabled
BRIGHTDATA_API_KEY=

# Optional veto dictionary database
NEON_DATABASE_URL=

# Railway should keep browser automation disabled unless you explicitly
# provision and validate a browser-capable runtime.
FITORNOT_ENABLE_BROWSER_AUTOMATION=0
FITORNOT_BROWSER_HEADLESS=true
FITORNOT_BROWSER_TIMEOUT_MS=45000
FITORNOT_BROWSER_SCROLL_ROUNDS=2

# Optional only when reusing a trusted remote Chrome session
FITORNOT_BROWSER_CDP_URL=

# Optional when seeding a trusted logged-in session on Railway.
# `FITORNOT_BROWSER_COOKIES_JSON` accepts either raw JSON or a `base64:...` payload.
# `FITORNOT_BROWSER_COOKIES_FILE` can point to a JSON file containing either
# a cookie array or {"cookies": [...]}.
FITORNOT_BROWSER_COOKIES_FILE=
FITORNOT_BROWSER_COOKIES_JSON=
