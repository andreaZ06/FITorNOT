# Required
DEEPSEEK_API_KEY=

# Recommended when Bright Data MCP fallback is enabled
BRIGHTDATA_API_KEY=

# Optional veto dictionary database
NEON_DATABASE_URL=

# Railway should keep browser automation disabled unless you explicitly
# provision and validate a browser-capable runtime.
FITORNOT_ENABLE_BROWSER_AUTOMATION=0
FITORNOT_BROWSER_HEADLESS=true
FITORNOT_BROWSER_TIMEOUT_MS=45000
FITORNOT_BROWSER_SCROLL_ROUNDS=2

# Optional service mode switch for a dedicated remote browser worker.
# Use `backend` for the FastAPI API service and `browser` for the noVNC + CDP browser service.
FITORNOT_SERVICE_MODE=backend

# Optional browser service settings when `FITORNOT_SERVICE_MODE=browser`.
FITORNOT_BROWSER_PUBLIC_PORT=
FITORNOT_BROWSER_CDP_PORT=9222
FITORNOT_BROWSER_CHROMIUM_CDP_PORT=9223
FITORNOT_BROWSER_VNC_PORT=5900
FITORNOT_BROWSER_PROFILE_DIR=/app/.browser-profile
FITORNOT_BROWSER_START_URL=https://www.jd.com/

# Optional only when reusing a trusted remote Chrome session
FITORNOT_BROWSER_CDP_URL=

# Optional when seeding a trusted logged-in session on Railway.
# `FITORNOT_BROWSER_COOKIES_JSON` accepts either raw JSON or a `base64:...` payload.
# `FITORNOT_BROWSER_COOKIES_FILE` can point to a JSON file containing either
# a cookie array or {"cookies": [...]}.
FITORNOT_BROWSER_COOKIES_FILE=
FITORNOT_BROWSER_COOKIES_JSON=

# Optional when seeding a compact Playwright storage state on Railway.
# `FITORNOT_BROWSER_STORAGE_STATE` accepts raw JSON or a `base64:...` gzip payload.
# `FITORNOT_BROWSER_STORAGE_STATE_FILE` can point to a JSON file containing a
# Playwright-style {"cookies": [...], "origins": [...]} payload.
FITORNOT_BROWSER_STORAGE_STATE_FILE=
FITORNOT_BROWSER_STORAGE_STATE=
